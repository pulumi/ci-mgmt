{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  extends: [
    'github>pulumi/renovate-config//default.json5',
  ],
  'github-actions': {
    managerFilePatterns: [
      '/.*/action-versions\\.ya?ml$/',
    ],
    ignorePaths: [
      'provider-ci/test-providers/**',
    ],
  },
  packageRules: [
    {
      matchPackageNames: [
        '*',
      ],
      postUpgradeTasks: {
        commands: [
          'make build',
        ],
        executionMode: 'branch',
      },
    },
    {
      matchManagers: [
        'github-actions',
      ],
      dependencyDashboardApproval: false,
      minimumReleaseAge: '7 days',
    },
    {
      matchManagers: [
        'github-actions',
      ],
      matchPackageNames: [
        'goreleaser/goreleaser-action',
      ],
      allowedVersions: '^5',
    },
    {
      matchManagers: [
        'github-actions',
      ],
      matchPackageNames: [
        'golangci/golangci-lint-action',
      ],
      allowedVersions: '^6',
    },
    {
      matchManagers: [
        'github-actions',
      ],
      matchPackageNames: [
        'pose/stale-issue-cleanup',
      ],
      enabled: false,
    },
  ],
}
